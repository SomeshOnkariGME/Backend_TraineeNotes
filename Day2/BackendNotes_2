Linux Command

mkdir foldername -- makedirectory (folder create karta hai)
cd foldername   ---us folder ke ander jana
pwd-- print working directories

rm-rf*  destroy wrong folder 
ls-- list file 
ls -la - hidden folder
mkdir -p project/src  --- eek folder ke ander eek or folder banana hai par parent exist he nahi karta tab -p use karte hai bina iske error ayega !!

touch filename -  file create karta hai 
touch filename -- agar file already exist karti hai to time update ho jayega varna new file create ho jayegi .

rm -- delete file 
rm -rf -- delete folder 

stat filename/folder  --give details of file and folder
ps aux -- show runnig process [Task Manager]

kill PID    --- we get pid throgh ps aux
kill -9 PID   -- force stop 

cp filename newfilename --- same destination mai file copy ho jati hai 
cp -r foldername newfoldername --copy folder with inside data 
cp filename [/path]  --- copy file one folder to another folder 
cp foldername[/path]  ---  copy folder one to  another destination only name not inside data with it 
mv filename newfile -- rename kar deta hai 


cat filename -- view file contant 
nano filename -- edit file contact 
find . -name "*.txt" -- find file 
ls - l --- file permission and file ownership 


